{
    "name": "kevinniel/developpement-par-les-tests",
    "description": "Base PHP avec PHPUnit pour pratiquer le developpement pilote par les tests.",
    "type": "project",
    "license": "proprietary",
    "require": {},
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test:unit": "phpunit --configuration phpunit.xml --testsuite unit",
        "test:integration": "phpunit --configuration phpunit.xml --testsuite integration",
        "test:e2e": "phpunit --configuration phpunit.xml --testsuite e2e"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
